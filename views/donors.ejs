
<h1>Donors</h1>

<div class="card">
    <h2>Add New Donor</h2>
    <form action="/donors" method="POST">
        <div>
            <label for="name">Name:</label>
            <input type="text" id="name" name="name" required>
        </div>
        <div>
            <label for="contact">Contact:</label>
            <input type="text" id="contact" name="contact" required>
        </div>
        <div>
            <label for="address">Address:</label>
            <textarea id="address" name="address" required></textarea>
        </div>
        <button type="submit">Add Donor</button>
    </form>
</div>

<div class="card">
    <h2>Existing Donors</h2>
    <% if (donors && donors.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% donors.forEach(donor => { %>
                    <tr>
                        <td><%= donor.name %></td>
                        <td><%= donor.contact %></td>
                        <td><%= donor.address %></td>
                        <td>
                            <a href="/donors/<%= donor.id %>/edit" class="btn btn-edit">Edit</a>
                            <form action="/donors/<%= donor.id %>/delete" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this donor?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>No donors found.</p>
    <% } %>
</div>

<%- include('layout-end') %>